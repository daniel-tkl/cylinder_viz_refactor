# Sample environment file for deployment (do NOT commit secrets)
# Copy to .env and populate production values.

# Application root (absolute path)
APP_ROOT=E:\apps\dev\cylinder_viz_refactor

# Streamlit internal port (listen on localhost)
STREAMLIT_PORT=8501

# Public IIS port (IIS will proxy from this port to STREAMLIT_PORT)
PUBLIC_PORT=8080

# Optional host header for DNS name binding (leave empty for IP:PORT access)
#HOST_HEADER=cylviz.local

# Service account (optional) - prefer gMSA or vault; do NOT store plaintext passwords in repo
#SERVICE_USER=MYDOMAIN\svc_cylviz
#SERVICE_PASS=PlainTextPassword   # recommend leaving blank and entering securely

# ARR / proxy settings
REQUEST_TIMEOUT=00:10:00
INSTALL_WEBSOCKETS=0
